[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"
waitForPort = 8081
ensurePreviewReachable = "/status"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server_dist/index.js"

[[workflows.workflow]]
name = "Deploy Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash deploy-frontend.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Deploy Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash deploy-backend.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Build AAB (Play Store)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash build-aab.sh"

[workflows.workflow.metadata]
outputType = "console"

